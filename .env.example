# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Data Sources
TUSHARE_TOKEN=your-tushare-token-here
EASTMONEY_API_KEY=your-eastmonety-key

# Cache Settings
DATA_CACHE_TTL=300

# Analysis Defaults
DEFAULT_KLINE_LIMIT=200
DEFAULT_MARKET=all

# CrewAI Settings
CREWAI_VERBOSE=true
MAX_ITERATIONS=5

# Celery (Redis)
# If your Redis server is running elsewhere, update this URL
REDIS_URL="redis://localhost:6379/0"
